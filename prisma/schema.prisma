generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String    @id @default(uuid())
  name      String
  username  String    @unique
  email     String    @unique
  role      UserRole  @default(STUDENT)
  password  String
  avatar    String?
  cover     String?
  birthDate DateTime? @map("birth_date")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  articles  Article[]
  events    Event[]

  @@map("users")
}

model Student {
  id                String                @id @default(uuid())
  code              String                @unique
  name              String
  gender            String?
  scholarship       String?
  financier         String?
  specialty         String?
  birthProvince     String?               @map("birth_province")
  birthDate         DateTime?             @map("birth_date") @db.Date
  idNumber          String?               @map("id_number")
  email             String?
  phone1            String?               @map("phone_1")
  phone2            String?               @map("phone_2")
  fatherAffiliation String?               @map("father_affiliation")
  motherAffiliation String?               @map("mother_affiliation")
  guardianName      String?               @map("guardian_name")
  guardianAddress   String?               @map("guardian_address")
  guardianPhone     String?               @map("guardian_phone")
  status            String?
  actualProvince    String?               @map("actual_province")
  actualDistrict    String?               @map("actual_district")
  currentOccupation String?               @map("current_occupation")
  companyName       String?               @map("company_name")
  companyPhone      String?               @map("company_phone")
  position          String?
  startYear         String?               @map("start_year")
  residencyRegime1  String?               @map("residency_regime_1")
  year1             String?               @map("year_1")
  level1            String?               @map("level_1")
  completionYear1   String?               @map("completion_year_1")
  observation1      String?               @map("observation_1")
  residencyRegime2  String?               @map("residency_regime_2")
  year2             String?               @map("year_2")
  level2            String?               @map("level_2")
  completionYear2   String?               @map("completion_year_2")
  observation2      String?               @map("observation_2")
  residencyRegime3  String?               @map("residency_regime_3")
  year3             String?               @map("year_3")
  level3            String?               @map("level_3")
  completionYear3   String?               @map("completion_year_3")
  observation3      String?               @map("observation_3")
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")
  approvalStatus    StudentApprovalStatus @default(NOT_APPROVED) @map("approval_status")
  qualificationId   String                @default("") @map("qualification_id")
  qualificationName String                @map("qualification_name")
  qualification     Qualification         @relation(fields: [qualificationId], references: [id], onDelete: Cascade)

  @@map("students")
}

model Certification {
  id           String   @id @default(uuid())
  name         String
  instituition String
  description  String
  startDate    String   @map("start_date")
  endDate      String   @map("end_date")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("certifications")
}

model Experience {
  id           String   @id @default(uuid())
  name         String
  description  String
  instituition String
  startDate    String   @map("start_date")
  endDate      String   @map("end_date")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("experience")
}

model Qualification {
  id             String    @id @default(uuid()) //change to cuid
  name           String
  description    String?
  bannerUrl      String?   @map("banner_url")
  workload       Int
  knowledgeAreas String?   @map("knowledge_areas")
  credits        Int
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  levels         Level[]
  students       Student[]

  @@map("qualifications")
}

model Level {
  id              String        @id @default(uuid())
  title           String
  description     String
  noticeUrl       String?       @map("notice_url")
  qualificationId String        @map("qualification_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  chapters        Chapter[]
  qualification   Qualification @relation(fields: [qualificationId], references: [id], onDelete: Cascade)

  @@map("levels")
}

model Chapter {
  id                        String   @id @default(uuid())
  content                   String
  supplementaryMaterialUrl1 String?  @map("supplementary_material_url_1")
  supplementaryMaterialUrl2 String?  @map("supplementary_material_url_2")
  levelId                   String   @map("level_id")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")
  level                     Level    @relation(fields: [levelId], references: [id], onDelete: Cascade)
  quizzes                   Quizz[]

  @@map("chapters")
}

model Quizz {
  id         String      @id @default(uuid())
  name       String      @unique
  chapterId  String      @map("chapter_id")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  quizzItems QuizzItem[]
  chapter    Chapter     @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@map("quizzes")
}

model QuizzItem {
  id        String   @id @default(uuid())
  question  String
  option1   String
  option2   String
  option3   String?
  option4   String?
  answer    String
  quizzId   String   @map("quizz_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  quizz     Quizz    @relation(fields: [quizzId], references: [id], onDelete: Cascade)

  @@map("quizz_items")
}

model Professor {
  id String @id @default(uuid())

  @@map("professors")
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String?
  location    String?
  type        EventType
  organizer   String?
  createdAt   DateTime  @default(now()) @map("created_at")
  createdById String    @map("created_by_id")
  endDate     DateTime? @map("end_date")
  imageUrl    String?   @map("image_url")
  isPublished Boolean   @default(false) @map("is_published")
  startDate   DateTime  @map("start_date")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@map("events")
}

model Article {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  content     String
  category    ArticleType
  tags        String?
  status      ArticleStatus @default(DRAFT)
  authorId    String        @map("author_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  imageUrl    String?       @map("image_url")
  isFeatured  Boolean       @default(false) @map("is_featured")
  publishedAt DateTime?     @map("published_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  author      User          @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("articles")
}

model JobVacancy {
  id          String   @id @default(cuid())
  title       String
  companyName String   @map("company_name")
  location    String
  url         String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("job_vacancies")
}

model Scholarship {
  id          String            @id @default(cuid())
  name        String
  description String?
  sponsor     String?
  amount      Float?
  type        String
  status      ScholarshipStatus @default(INACTIVE)
  createdAt   DateTime          @default(now()) @map("created_at")
  endDate     DateTime?         @map("end_date")
  startDate   DateTime?         @map("start_date")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@map("scholarships")
}

enum UserRole {
  ADMIN
  STUDENT
  GRADUETE
  TEACHER
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUETED
}

enum StudentApprovalStatus {
  APPROVED
  NOT_APPROVED
}

enum EventType {
  TRAINING
  SEMINAR
  CONFERENCE
}

enum ArticleType {
  INNOVATION
  PUBLICATION
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ScholarshipStatus {
  ACTIVE
  INACTIVE
  CLOSED
}
